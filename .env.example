DATABASE_URL=sqlite+aiosqlite:///./data/store_intelligence.db
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
STALE_FEED_THRESHOLD_MINUTES=10
ANOMALY_QUEUE_SPIKE_THRESHOLD=5
ANOMALY_CONVERSION_DROP_PCT=0.20
DEAD_ZONE_MINUTES=30
DWELL_EVENT_INTERVAL_SECONDS=30
MAX_INGEST_BATCH=500

# Pipeline settings
YOLO_MODEL=yolov8n.pt
DETECTION_CONFIDENCE=0.35
DETECTION_DEVICE=cpu
API_INGEST_URL=http://localhost:8000/events/ingest

# Store config
DEFAULT_STORE_ID=STORE_BLR_002
